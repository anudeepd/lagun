    },
    {
      "label": "delete without where",
      "sql": "DELETE FROM users",
      "expected_code": "MISSING_WHERE"
    },
    {
      "label": "start transaction",
      "sql": "START TRANSACTION",
      "expected_code": "UNSUPPORTED_STATEMENT"
    },
    {
      "label": "commit",
      "sql": "COMMIT",
      "expected_code": "UNSUPPORTED_STATEMENT"
    },
    {
      "label": "rollback",
      "sql": "ROLLBACK",
      "expected_code": "UNSUPPORTED_STATEMENT"
    },
    {
      "label": "mysql versioned comment",
